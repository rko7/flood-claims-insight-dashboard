<!DOCTYPE html>
<html>
<head>
  <title>{{ title }}</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <h1>{{ title }}</h1>
  <p><strong>Message:</strong> {{ message }}</p>

  {{#warning}}
    <p><strong>Warning:</strong> {{ warning }}</p>
  {{/warning}}

  {{#error}}
    <p><strong>Error:</strong> {{ error }}</p>
  {{/error}}
  <h2>Watchlist</h2>

{{#hasError}}
  <p>Error loading watchlist.</p>
{{/hasError}}

{{#watchlist}}
  <div>
    {{claim_id}} ({{state}}) - {{year}} - {{amount}}
  </div>
{{/watchlist}}

{{^watchlist}}
  <p>No saved claims yet.</p>
{{/watchlist}}
</body>
</html>