<!DOCTYPE html>
<html>
<head>
  <title>{{ title }}</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body data-state="{{form.state}}" data-toast="{{error}}">
  {{> nav}}
  
  <h1>{{ title }}</h1>

  {{#warning}}
    <p><strong>Warning:</strong> {{ warning }}</p>
  {{/warning}}

  {{#error}}
    <p><strong>Error:</strong> {{ error }}</p>
  {{/error}}

  <h2>Watchlist</h2>

  {{#hasError}}
    <p>Error loading watchlist.</p>
  {{/hasError}}

  {{#watchlist}}
    {{#firstRow}}
    <table class="stack-table" border="1" cellpadding="6">
      <tr>
        <th>Claim ID</th>
        <th>State</th>
        <th>Year</th>
        <th>Amount ($)</th>
        <th>Flood Zone</th>
        <th>Actions</th>
      </tr>
    {{/firstRow}}

      <tr>
        <td><a href="/claims/{{claim_id}}">{{claim_id}}</a></td>
        <td>{{state}}</td>
        <td>{{year}}</td>
        <td>{{amount}}</td>
        <td>
          {{#flood_zone}}{{flood_zone}}{{/flood_zone}}
          {{^flood_zone}}-{{/flood_zone}}
        </td>
        <td>
          <form method="post" action="/watchlist/delete" style="display:inline;">
            <input type="hidden" name="id" value="{{id}}">
            <button type="submit">Delete</button>
          </form>
        </td>
      </tr>

    {{#lastRow}}
    </table>
    {{/lastRow}}
  {{/watchlist}}

  {{^watchlist}}
    <p>No saved claims yet.</p>
  {{/watchlist}}

  <h2>Add to Watchlist</h2>

  <form method="post" action="/watchlist/add">
    <div class="form-row">
      <label class="form-label">Claim ID:</label>
      <input
        type="text"
        name="claim_id"
        required
        minlength="6"
        maxlength="80"
        pattern="[A-Za-z0-9-]{6,80}"
        value="{{form.claim_id}}">
      <small>Allowed: letters, numbers, hyphen (6 to 80 chars)</small>
    </div>

    <div class="form-row">
      <label class="form-label">State:</label>
      <select name="state" id="stateSelectHome" required>
        <option value="">-</option>
        <option value="AL">AL</option>
        <option value="AK">AK</option>
        <option value="AZ">AZ</option>
        <option value="AR">AR</option>
        <option value="CA">CA</option>
        <option value="CO">CO</option>
        <option value="CT">CT</option>
        <option value="DE">DE</option>
        <option value="DC">DC</option>
        <option value="FL">FL</option>
        <option value="GA">GA</option>
        <option value="HI">HI</option>
        <option value="ID">ID</option>
        <option value="IL">IL</option>
        <option value="IN">IN</option>
        <option value="IA">IA</option>
        <option value="KS">KS</option>
        <option value="KY">KY</option>
        <option value="LA">LA</option>
        <option value="ME">ME</option>
        <option value="MD">MD</option>
        <option value="MA">MA</option>
        <option value="MI">MI</option>
        <option value="MN">MN</option>
        <option value="MS">MS</option>
        <option value="MO">MO</option>
        <option value="MT">MT</option>
        <option value="NE">NE</option>
        <option value="NV">NV</option>
        <option value="NH">NH</option>
        <option value="NJ">NJ</option>
        <option value="NM">NM</option>
        <option value="NY">NY</option>
        <option value="NC">NC</option>
        <option value="ND">ND</option>
        <option value="OH">OH</option>
        <option value="OK">OK</option>
        <option value="OR">OR</option>
        <option value="PA">PA</option>
        <option value="RI">RI</option>
        <option value="SC">SC</option>
        <option value="SD">SD</option>
        <option value="TN">TN</option>
        <option value="TX">TX</option>
        <option value="UT">UT</option>
        <option value="VT">VT</option>
        <option value="VA">VA</option>
        <option value="WA">WA</option>
        <option value="WV">WV</option>
        <option value="WI">WI</option>
        <option value="WY">WY</option>
      </select>
    </div>

    <div class="form-row">
      <label class="form-label">Loss Date:</label>
      <input type="date" name="year" value="{{form.year}}" min="1978-01-01" max="2100-12-31">
      <small>This date sets the year.</small>
    </div>

    <div class="form-row">
      <label class="form-label">Amount ($):</label>
      <input type="number" step="0.01" min="0" name="amount" value="{{form.amount}}">
    </div>

    <button type="submit">Add</button>
  </form>

  <script>
    (function () {
      var s = document.body.getAttribute("data-state") || "";
      var el = document.getElementById("stateSelectHome");
      if (el && s) el.value = s;
    })();
  </script>

  <!-- Toast  -->
  <script src="/js/toast.js"></script>
</body>
</html>