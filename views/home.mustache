<!DOCTYPE html>
<html>
<head>
  <title>{{ title }}</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <h1>{{ title }}</h1>
  <p><strong>Message:</strong> {{ message }}</p>

  {{#warning}}
    <p><strong>Warning:</strong> {{ warning }}</p>
  {{/warning}}

  {{#error}}
    <p><strong>Error:</strong> {{ error }}</p>
  {{/error}}

  <!-- Watchlist section -->
  <h2>Watchlist</h2>

  {{#hasError}}
    <p>Error loading watchlist.</p>
  {{/hasError}}

  {{#watchlist}}
    <div>
      {{claim_id}} ({{state}}) - {{year}} - {{amount}}

      <form method="post" action="/watchlist/delete" style="display:inline;">
        <input type="hidden" name="id" value="{{id}}">
        <button type="submit">Delete</button>
      </form>
    </div>
  {{/watchlist}}

  {{^watchlist}}
    <p>No saved claims yet.</p>
  {{/watchlist}}

  <!-- Add to watchlist form -->
  <h2>Add to Watchlist</h2>

  <form method="post" action="/watchlist/add">
    <div>
      Claim ID:
      <input type="text" name="claim_id" required>
    </div>
    <div>
      State:
      <input type="text" name="state" required>
    </div>
    <div>
      Year:
      <input type="number" name="year">
    </div>
    <div>
      Amount:
      <input type="number" step="0.01" name="amount">
    </div>
    <button type="submit">Add</button>
  </form>
</body>
</html>