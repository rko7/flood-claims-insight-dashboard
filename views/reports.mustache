<!DOCTYPE html>
<html>
<head>
  <title>{{ title }}</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body data-toast="{{toastError}}">
  {{> nav}}

  <h1>{{ title }}</h1>

  {{#toastError}}
    <p><strong>Error:</strong> {{ toastError }}</p>
  {{/toastError}}

  {{#reports}}
    {{#firstRow}}
    <table class="stack-table" border="1" cellpadding="6">
      <tr>
        <th>Name</th>
        <th>Filters</th>
        <th>Created</th>
      </tr>
    {{/firstRow}}

      <tr>
        <td>{{report_name}}</td>
        <td>
          {{#state}}State: {{state}} {{/state}}
          {{#from_date}}From: {{from_date}} {{/from_date}}
          {{#to_date}}To: {{to_date}} {{/to_date}}
          {{#min_paid}}Min: ${{min_paid}} {{/min_paid}}
          {{^state}}{{^from_date}}{{^to_date}}{{^min_paid}}-{{/min_paid}}{{/to_date}}{{/from_date}}{{/state}}
        </td>
        <td>{{created_at}}</td>
      </tr>

    {{#lastRow}}
    </table>
    {{/lastRow}}
  {{/reports}}

  {{^reports}}
    <p>No saved reports yet.</p>
  {{/reports}}

  <script src="/js/toast.js"></script>
</body>
</html>