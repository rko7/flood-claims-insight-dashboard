<!DOCTYPE html>
<html>
<head>
  <title>{{ title }}</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body data-toast="{{toastError}}">
  {{> nav}}

  <h1>{{ title }}</h1>

  {{#toastError}}
    <p><strong>Error:</strong> {{ toastError }}</p>
  {{/toastError}}

  <!-- Back -->
  <p><a href="/claims/{{claimId}}">Back to Details</a></p>

  <!-- Edit form -->
  <form method="post" action="/notes/update">
    <input type="hidden" name="note_id" value="{{note.id}}">
    <input type="hidden" name="claim_id" value="{{claimId}}">

    <div class="form-row">
      <label class="form-label">Priority:</label>
      <select name="priority">
        <option value="">-</option>
        <option value="1" {{#isP1}}selected{{/isP1}}>1: Most important</option>
        <option value="2" {{#isP2}}selected{{/isP2}}>2: High</option>
        <option value="3" {{#isP3}}selected{{/isP3}}>3: Medium</option>
        <option value="4" {{#isP4}}selected{{/isP4}}>4: Low</option>
        <option value="5" {{#isP5}}selected{{/isP5}}>5: Lowest</option>
      </select>
    </div>

    <div class="form-row">
      <label class="form-label">Note:</label>
      <textarea name="note_text" rows="4" cols="40" required minlength="5" maxlength="300">{{note.note_text}}</textarea>
      <small>5 to 300 characters</small>
    </div>

    <button type="submit">Update Note</button>
  </form>

  <script src="/js/toast.js"></script>
</body>
</html>