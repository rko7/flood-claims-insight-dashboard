<!DOCTYPE html>
<html>
<head>
  <title>{{ title }}</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body data-toast="{{toastError}}">
  {{> nav}}

  <h1>{{ title }}</h1>

  <p><a href="/claims">Back to Claims</a></p>

  <h2>{{claim.claimId}}</h2>

  <!-- Claim info -->
  <table class="detail-table" border="1" cellpadding="6">
    <tr><th>State</th><td>{{claim.state}}</td></tr>
    <tr><th>Loss Date</th><td>{{claim.lossDate}}</td></tr>
    <tr><th>Year</th><td>{{claim.year}}</td></tr>
    <tr><th>Paid Amount ($)</th><td>{{claim.paidAmount}}</td></tr>
    <tr><th>Source</th><td>{{claim.source}}</td></tr>
  </table>

  <h2>Notes</h2>

  {{#hasNotesError}}
    <p>Error loading notes.</p>
  {{/hasNotesError}}

  {{#notes}}
    <!-- Notes table -->
    {{#firstNote}}
    <table border="1" cellpadding="6">
      <tr>
        <th>Priority</th>
        <th>Note</th>
        <th>Created</th>
        <th>Actions</th>
      </tr>
    {{/firstNote}}

      <tr>
        <td>
          {{#isP1}}1: Most important{{/isP1}}
          {{#isP2}}2: High{{/isP2}}
          {{#isP3}}3: Medium{{/isP3}}
          {{#isP4}}4: Low{{/isP4}}
          {{#isP5}}5: Lowest{{/isP5}}
          {{#isNoPriority}}-{{/isNoPriority}}
        </td>
        <td>{{note_text}}</td>
        <td>{{created_at}}</td>
        <td>
          <form method="get" action="/notes/{{id}}/edit" style="display:inline;">
            <input type="hidden" name="claim_id" value="{{claim.claimId}}">
            <button type="submit">Edit</button>
          </form>

          <form method="post" action="/notes/delete" style="display:inline;">
            <input type="hidden" name="claim_id" value="{{claim.claimId}}">
            <input type="hidden" name="note_id" value="{{id}}">
            <button type="submit">Delete</button>
          </form>
        </td>
      </tr>

    {{#lastNote}}
    </table>
    {{/lastNote}}
  {{/notes}}

  {{^notes}}
    <p>No notes yet.</p>
  {{/notes}}

  <!-- Add note -->
  <h2>Add Note</h2>

  <form method="post" action="/notes/add">
    <input type="hidden" name="claim_id" value="{{claim.claimId}}">

    <div class="form-row">
      <label class="form-label">Priority:</label>
      <select name="priority">
        <option value="">-</option>
        <option value="1" {{noteForm.selected1}}>1: Most important</option>
        <option value="2" {{noteForm.selected2}}>2: High</option>
        <option value="3" {{noteForm.selected3}}>3: Medium</option>
        <option value="4" {{noteForm.selected4}}>4: Low</option>
        <option value="5" {{noteForm.selected5}}>5: Lowest</option>
      </select>
    </div>

    <div class="form-row">
      <label class="form-label">Note:</label>
      <textarea name="note_text" rows="4" cols="40" required minlength="5" maxlength="300">{{noteForm.note_text}}</textarea>
      <small>5 to 300 characters</small>
    </div>

    <button type="submit">Save Note</button>
  </form>

  <script src="/js/toast.js"></script>
</body>
</html>