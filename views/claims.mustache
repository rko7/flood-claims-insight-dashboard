<!DOCTYPE html>
<html>
<head>
  <title>{{ title }}</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body data-state="{{filters.state}}" data-toast="{{toastError}}">
  {{> nav}}

  <h1>{{ title }}</h1>

  {{#toastError}}
    <p><strong>Error:</strong> {{ toastError }}</p>
  {{/toastError}}

  <!-- Filters -->
  <form method="get" action="/claims">
    <div class="form-row">
      <label class="form-label">State:</label>
      <select name="state" id="stateSelect">
        <option value="">-</option>

        <!-- US States + DC -->
        <option value="AL">AL</option>
        <option value="AK">AK</option>
        <option value="AZ">AZ</option>
        <option value="AR">AR</option>
        <option value="CA">CA</option>
        <option value="CO">CO</option>
        <option value="CT">CT</option>
        <option value="DE">DE</option>
        <option value="DC">DC</option>
        <option value="FL">FL</option>
        <option value="GA">GA</option>
        <option value="HI">HI</option>
        <option value="ID">ID</option>
        <option value="IL">IL</option>
        <option value="IN">IN</option>
        <option value="IA">IA</option>
        <option value="KS">KS</option>
        <option value="KY">KY</option>
        <option value="LA">LA</option>
        <option value="ME">ME</option>
        <option value="MD">MD</option>
        <option value="MA">MA</option>
        <option value="MI">MI</option>
        <option value="MN">MN</option>
        <option value="MS">MS</option>
        <option value="MO">MO</option>
        <option value="MT">MT</option>
        <option value="NE">NE</option>
        <option value="NV">NV</option>
        <option value="NH">NH</option>
        <option value="NJ">NJ</option>
        <option value="NM">NM</option>
        <option value="NY">NY</option>
        <option value="NC">NC</option>
        <option value="ND">ND</option>
        <option value="OH">OH</option>
        <option value="OK">OK</option>
        <option value="OR">OR</option>
        <option value="PA">PA</option>
        <option value="RI">RI</option>
        <option value="SC">SC</option>
        <option value="SD">SD</option>
        <option value="TN">TN</option>
        <option value="TX">TX</option>
        <option value="UT">UT</option>
        <option value="VT">VT</option>
        <option value="VA">VA</option>
        <option value="WA">WA</option>
        <option value="WV">WV</option>
        <option value="WI">WI</option>
        <option value="WY">WY</option>
      </select>
    </div>

    <div class="form-row">
      <label class="form-label">From:</label>
      <input type="date" name="from" value="{{filters.from}}" min="1978-01-01" max="2100-12-31">
      <small>Valid range: 1978 to present</small>
    </div>

    <div class="form-row">
      <label class="form-label">To:</label>
      <input type="date" name="to" value="{{filters.to}}" min="1978-01-01" max="2100-12-31">
    </div>

    <div class="form-row">
      <label class="form-label">Min Paid ($):</label>
      <input type="number" step="0.01" min="0" name="minPaid" value="{{filters.minPaid}}">
    </div>

    <div class="form-row">
      <label class="form-label">Max Paid ($):</label>
      <input type="number" step="0.01" min="0" name="maxPaid" value="{{filters.maxPaid}}">
    </div>

    <div class="form-row">
      <label class="form-label">Flood Zone:</label>
      <select name="floodZone" id="zoneSelect">
        <option value="">-</option>

        <optgroup label="High risk (A zones)">
          <option value="AE">AE</option>
          <option value="A">A</option>
          <option value="AO">AO</option>
          <option value="AH">AH</option>
          <option value="A99">A99</option>
          <option value="AR">AR</option>
        </optgroup>

        <optgroup label="Coastal high risk (V zones)">
          <option value="VE">VE</option>
          <option value="V">V</option>
        </optgroup>

        <optgroup label="Lower or moderate risk">
          <option value="X">X</option>
        </optgroup>

        <optgroup label="Other / legacy">
          <option value="B">B</option>
          <option value="C">C</option>
          <option value="D">D</option>
        </optgroup>
      </select>
      <small>Tip: A/AE = high risk. V/VE = coastal high risk. X = lower risk.</small>
    </div>

    <!-- Cause of Damage -->
    <div class="form-row">
      <label class="form-label">Cause:</label>
      <select name="cause" id="causeSelect">
        <option value="">-</option>

        <option value="0">0: Other causes</option>
        <option value="1">1: Tidal water overflow</option>
        <option value="2">2: Stream/river/lake overflow</option>
        <option value="3">3: Alluvial fan overflow</option>
        <option value="4">4: Rainfall or snowmelt</option>
        <option value="7">7: Erosion-demolition (pre-1995)</option>
        <option value="8">8: Erosion-removal (pre-1995)</option>
        <option value="9">9: Earth movement</option>
        <option value="A">A: Closed basin lake</option>
        <option value="B">B: Expedited (no inspection)</option>
        <option value="C">C: Expedited (follow-up inspection)</option>
        <option value="D">D: Remote adjustment</option>
      </select>
      <small>Pick one. Some claims can have more than one code, but this filter matches one code.</small>
    </div>

    <button type="submit">Apply</button>
    <a class="button-link" href="/claims">Reset</a>
  </form>

  {{#hasResults}}
    <h2>Claim Results</h2>

    <table class="stack-table" border="1" cellpadding="6">
      <tr>
        <th>Claim ID</th>
        <th>State</th>
        <th>Loss Date</th>
        <th>Flood Zone</th>
        <th>Cause</th>
        <th>Paid Amount ($)</th>
        <th>View</th>
        <th>Save</th>
      </tr>

      {{#results}}
      <tr>
        <td>{{claimId}}</td>
        <td>{{state}}</td>
        <td>{{lossDate}}</td>

        <td>
          {{#floodZone}}{{floodZone}}{{/floodZone}}
          {{^floodZone}}-{{/floodZone}}
        </td>

        <td>
          {{#cause}}{{cause}}{{/cause}}
          {{^cause}}-{{/cause}}
        </td>

        <td>{{paidAmount}}</td>

        <td>
          <form method="get" action="/claims/{{claimId}}" style="display:inline;">
            <button type="submit">View</button>
          </form>
        </td>

        <td>
          <form method="post" action="/watchlist/add" style="display:inline;">
            <input type="hidden" name="claim_id" value="{{claimId}}">
            <input type="hidden" name="state" value="{{state}}">
            <input type="hidden" name="year" value="{{year}}">
            <input type="hidden" name="amount" value="{{paidAmount}}">
            <input type="hidden" name="source" value="claims">
            <button type="submit">Save</button>
          </form>
        </td>
      </tr>
      {{/results}}
    </table>
  {{/hasResults}}

  {{^hasResults}}
    {{#hasFilters}}
      {{^apiUnavailable}}
        <p>No results found.</p>
      {{/apiUnavailable}}
    {{/hasFilters}}
  {{/hasResults}}

  <script>
    (function () {
      var s = document.body.getAttribute("data-state") || "";
      var el = document.getElementById("stateSelect");
      if (el && s) el.value = s;

      var z = "{{filters.floodZone}}";
      var zEl = document.getElementById("zoneSelect");
      if (zEl && z) zEl.value = z;

      var c = "{{filters.cause}}";
      var cEl = document.getElementById("causeSelect");
      if (cEl && c) cEl.value = c;
    })();
  </script>

  <!-- Toast -->
  <script src="/js/toast.js"></script>
</body>
</html>