<!DOCTYPE html>
<html>
<head>
  <title>{{ title }}</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  {{> nav}}

  <h1>{{ title }}</h1>
  <p><strong>Message:</strong> {{ message }}</p>

  {{#warning}}
    <p><strong>Warning:</strong> {{ warning }}</p>
  {{/warning}}

  {{#error}}
    <p><strong>Error:</strong> {{ error }}</p>
  {{/error}}

  <!-- Filters -->
  <form method="get" action="/claims">
    <div class="form-row">
      <label class="form-label">State:</label>
      <input type="text" name="state" value="{{filters.state}}">
    </div>

    <div class="form-row">
      <label class="form-label">From:</label>
      <input type="date" name="from" value="{{filters.from}}">
    </div>

    <div class="form-row">
      <label class="form-label">To:</label>
      <input type="date" name="to" value="{{filters.to}}">
    </div>

    <div class="form-row">
      <label class="form-label">Min paid:</label>
      <input type="number" step="0.01" name="minPaid" value="{{filters.minPaid}}">
    </div>

    <button type="submit">Apply</button>
    <a href="/claims">Reset</a>
  </form>

  {{#hasFilters}}
    <p>Filters applied.</p>
  {{/hasFilters}}

  {{#hasResults}}
    <!-- Results -->
    <h2>Claim Results</h2>

    <table border="1" cellpadding="6">
      <tr>
        <th>Claim ID</th>
        <th>State</th>
        <th>Loss Date</th>
        <th>Paid Amount</th>
        <th>View</th>
        <th>Save</th>
      </tr>

      {{#results}}
        <tr>
          <td>{{claimId}}</td>
          <td>{{state}}</td>
          <td>{{lossDate}}</td>
          <td>{{paidAmount}}</td>
          <td>
            <a href="/claims/{{claimId}}">View</a>
          </td>
          <td>
            <form method="post" action="/watchlist/add">
              <input type="hidden" name="claim_id" value="{{claimId}}">
              <input type="hidden" name="state" value="{{state}}">
              <input type="hidden" name="year" value="{{year}}">
              <input type="hidden" name="amount" value="{{paidAmount}}">
              <input type="hidden" name="source" value="claims">
              <button type="submit">Save</button>
            </form>
          </td>
        </tr>
      {{/results}}
    </table>
  {{/hasResults}}
</body>
</html>